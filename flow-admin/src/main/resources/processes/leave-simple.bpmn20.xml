<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             targetNamespace="http://flowable.org/examples">

  <!--
    简单请假流程 Demo
    流程说明：
    1. 员工提交请假申请
    2. 部门经理审批（如果请假天数 <= 3天）
    3. 总经理审批（如果请假天数 > 3天）
    4. 审批通过后人事备案
    5. 审批拒绝则流程结束
  -->

  <process id="leave-simple" name="简单请假流程" isExecutable="true">

    <!-- 开始节点 -->
    <startEvent id="start" name="开始" />

    <!-- 提交请假申请 -->
    <userTask id="submit-leave" name="提交请假申请"
              flowable:assignee="${startUserId}"
              flowable:formKey="leave-form">
      <documentation>
        申请人填写请假信息：
        - 请假类型（事假/病假/年假等）
        - 开始时间
        - 结束时间
        - 请假天数
        - 请假原因
      </documentation>
    </userTask>

    <!-- 计算请假天数网关 -->
    <exclusiveGateway id="days-gateway" name="判断请假天数" />

    <!-- 部门经理审批（<=3天） -->
    <userTask id="manager-approval" name="部门经理审批"
              flowable:assignee="${managerId}">
      <documentation>
        部门经理审批请假申请：
        - 审核请假理由
        - 确认工作安排
        - 批准或拒绝
      </documentation>
    </userTask>

    <!-- 总经理审批（>3天） -->
    <userTask id="gm-approval" name="总经理审批"
              flowable:assignee="${gmId}">
      <documentation>
        总经理审批长假申请：
        - 审核长期请假必要性
        - 评估业务影响
        - 批准或拒绝
      </documentation>
    </userTask>

    <!-- 审批结果网关 -->
    <exclusiveGateway id="result-gateway" name="审批结果" />

    <!-- 人事备案 -->
    <userTask id="hr-record" name="人事备案"
              flowable:assignee="${hrId}">
      <documentation>
        人事部门备案：
        - 记录请假信息
        - 更新考勤系统
        - 归档请假单
      </documentation>
    </userTask>

    <!-- 结束节点 -->
    <endEvent id="end-approve" name="审批通过" />
    <endEvent id="end-reject" name="审批拒绝" />

    <!-- ========== 流程连线 ========== -->

    <!-- 开始 -> 提交申请 -->
    <sequenceFlow id="flow1" sourceRef="start" targetRef="submit-leave" />

    <!-- 提交申请 -> 判断天数 -->
    <sequenceFlow id="flow2" sourceRef="submit-leave" targetRef="days-gateway" />

    <!-- 小于等于3天 -> 部门经理审批 -->
    <sequenceFlow id="flow3" sourceRef="days-gateway" targetRef="manager-approval" name="≤3天">
      <conditionExpression xsi:type="tFormalExpression">${leaveDays &lt;= 3}</conditionExpression>
    </sequenceFlow>

    <!-- 大于3天 -> 总经理审批 -->
    <sequenceFlow id="flow4" sourceRef="days-gateway" targetRef="gm-approval" name="&gt;3天">
      <conditionExpression xsi:type="tFormalExpression">${leaveDays &gt; 3}</conditionExpression>
    </sequenceFlow>

    <!-- 部门经理审批 -> 审批结果 -->
    <sequenceFlow id="flow5" sourceRef="manager-approval" targetRef="result-gateway" />

    <!-- 总经理审批 -> 审批结果 -->
    <sequenceFlow id="flow6" sourceRef="gm-approval" targetRef="result-gateway" />

    <!-- 审批通过 -> 人事备案 -->
    <sequenceFlow id="flow7" sourceRef="result-gateway" targetRef="hr-record" name="批准">
      <conditionExpression xsi:type="tFormalExpression">${approved == true}</conditionExpression>
    </sequenceFlow>

    <!-- 审批拒绝 -> 结束 -->
    <sequenceFlow id="flow8" sourceRef="result-gateway" targetRef="end-reject" name="拒绝">
      <conditionExpression xsi:type="tFormalExpression">${approved == false}</conditionExpression>
    </sequenceFlow>

    <!-- 人事备案 -> 结束 -->
    <sequenceFlow id="flow9" sourceRef="hr-record" targetRef="end-approve" />

  </process>

</definitions>
